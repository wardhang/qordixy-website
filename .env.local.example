# ─── SMTP Configuration ───────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your SMTP credentials.
# Never commit .env.local to version control.

# SMTP server hostname
# Gmail:     smtp.gmail.com
# Outlook:   smtp.office365.com
# Zoho:      smtp.zoho.com
# Custom:    mail.yourdomain.com
SMTP_HOST=smtp.gmail.com

# SMTP port — 587 (STARTTLS, recommended) or 465 (SSL)
SMTP_PORT=587

# Your SMTP login email (the "from" address)
SMTP_USER=noreply@qordixy.com

# SMTP password or App Password
# Gmail users: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_PASS=your_smtp_password_here
